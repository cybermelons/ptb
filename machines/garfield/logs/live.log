    # Property sets
    "72e39547-7b18-11d1-adef-00c04fd8d5cd": "DNS Host Name Attributes (PS)",
    "b8119fd0-04f6-4762-ab7a-4986c76b3f9a": "Other Domain Parameters (PS)",
    "ffa6f046-ca4b-4feb-b40d-04dfee722543": "MS-TS-GatewayAccess (PS)",
    "037088f8-0ae1-11d2-b422-00a0c968f939": "RAS Information (PS)",
    "4c164200-20c0-11d0-a768-00aa006e0529": "User Account Restrictions (PS)",
