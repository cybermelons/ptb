if it_sid: target_sids.add(it_sid)

print(f"Total ACEs on l.wilson: {len(aces)}")
print(f"\n=== ACEs matching j.arbuckle / IT Support ===")

matching = []
for ace in aces:
    if ace['trustee'] in target_sids:
        matching.append(ace)
        mask = ace['access_mask']
        obj_guid = ace['object_type'] or "N/A"
        inh_guid = ace['inherited_object_type'] or "N/A"
        guid_name = KNOWN_GUIDS.get(obj_guid, "UNKNOWN") if obj_guid != "N/A" else "N/A"
        inh_name = KNOWN_GUIDS.get(inh_guid, "UNKNOWN") if inh_guid != "N/A" else "N/A"
        rights = []
        if mask & 0x20: rights.append("WriteProp")
        if mask & 0x08: rights.append("Self")
        if mask & 0x40000000: rights.append("GenericWrite")
        if mask & 0x40000: rights.append("WriteDACL")
        if mask & 0x80000: rights.append("WriteOwner")
        if mask & 0x10000000: rights.append("GenericAll")
        if mask & 0x100: rights.append("ControlAccess")
        if mask & 0x04: rights.append("CreateChild")
        if mask & 0x10: rights.append("DeleteTree")
        if mask & 0x80: rights.append("ReadProp")
        print(f"  ACE Type: {ace['type']}, Mask: 0x{mask:08x} ({','.join(rights)})")
        print(f"    ObjectType: {obj_guid} ({guid_name})")
        print(f"    InheritedObjectType: {inh_guid} ({inh_name})")
        print(f"    Trustee: {ace['trustee']}")
        print()

if not matching:
    print("  NO matching ACEs found!")

# Resolve unknown GUIDs
unknown_guids = set()
for ace in matching:
    for g in [ace['object_type'], ace['inherited_object_type']]:
        if g and g not in KNOWN_GUIDS:
            unknown_guids.add(g)

if unknown_guids:
    print("\n=== Resolving unknown GUIDs ===")
    for guid in unknown_guids:
        guid_bytes = uuid.UUID(guid).bytes_le
        escaped = escape_bytes(guid_bytes)
        conn.search(f"CN=Schema,CN=Configuration,DC=garfield,DC=htb",
                    f"(schemaIDGUID={escaped})", attributes=["lDAPDisplayName"])
        if conn.entries:
            name = conn.entries[0].lDAPDisplayName.value
            print(f"  {guid} => {name}")
        else:
            conn.search(f"CN=Extended-Rights,CN=Configuration,DC=garfield,DC=htb",
                        f"(rightsGuid={guid})", attributes=["cn", "displayName"])
            if conn.entries:
                print(f"  {guid} => ExtRight: {conn.entries[0].cn.value}")
            else:
                print(f"  {guid} => NOT FOUND")

# Also check: does j.arbuckle have write perms on OTHER users?
print("\n=== Checking IT Support ACEs on ALL domain users ===")
conn.search("DC=garfield,DC=htb", "(&(objectClass=user)(objectCategory=person))",
            attributes=["distinguishedName", "sAMAccountName", "nTSecurityDescriptor"],
            controls=[sd_control])

for entry in conn.entries:
    raw = entry.nTSecurityDescriptor.raw_values[0] if entry.nTSecurityDescriptor.raw_values else None
    if not raw: continue
    user_aces = parse_sd(raw)
    user_matching = [a for a in user_aces if a['trustee'] in target_sids and a['access_mask'] & 0x20]
    if user_matching:
        sam = entry.sAMAccountName.value
        for a in user_matching:
            guid = a['object_type'] or "ALL"
            gname = KNOWN_GUIDS.get(guid, guid) if guid != "ALL" else "ALL"
            print(f"  {sam}: WriteProp on {gname} (mask=0x{a['access_mask']:08x})")

conn.unbind()
PYEOF
python3 /tmp/enum_aces3.py
