import socket, sys
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.settimeout(10)
s.connect(('10.129.17.178', 2179))
# Send RDP negotiation request (Cookie + NEG_REQ)
rdp_neg = bytes.fromhex('030000130ee00000000000010008000300000000')
s.send(rdp_neg)
data = s.recv(4096)
print('Received {} bytes'.format(len(data)))
print('Hex:', data.hex())
print('ASCII:', repr(data))
s.close()
" 2>&1; echo "---EXIT:$?---"
[10:23:10] RUN: python3 -c "
import socket
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.settimeout(10)
s.connect(('10.129.17.178', 2179))
# Just wait for banner
import select
ready = select.select([s], [], [], 5)
if ready[0]:
    data = s.recv(4096)
    print('Banner ({} bytes): {}'.format(len(data), data.hex()))
    print('ASCII:', repr(data))
else:
    print('No banner received in 5s, sending probe...')
    # Try sending HTTP probe
    s.send(b'GET / HTTP/1.0\r\n\r\n')
    data = s.recv(4096)
    print('HTTP response ({} bytes): {}'.format(len(data), repr(data)))
s.close()
" 2>&1; echo "---EXIT:$?---"
