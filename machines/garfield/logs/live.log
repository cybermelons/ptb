    raw = data[offset:offset+16]
    if len(raw) < 16:
        return None
    return str(uuid.UUID(bytes_le=raw))

def parse_sd(raw_sd):
    """Parse nTSecurityDescriptor binary and extract ACEs"""
    if not raw_sd:
        return []
    
    revision = struct.unpack_from('<B', raw_sd, 0)[0]
    control = struct.unpack_from('<H', raw_sd, 2)[0]
    dacl_offset = struct.unpack_from('<I', raw_sd, 16)[0]
    
    if dacl_offset == 0:
        return []
    
    acl_revision = struct.unpack_from('<B', raw_sd, dacl_offset)[0]
    acl_size = struct.unpack_from('<H', raw_sd, dacl_offset+2)[0]
    ace_count = struct.unpack_from('<H', raw_sd, dacl_offset+4)[0]
    
    aces = []
    offset = dacl_offset + 8
    
    for i in range(ace_count):
        if offset >= len(raw_sd):
            break
        ace_type = struct.unpack_from('<B', raw_sd, offset)[0]
        ace_flags = struct.unpack_from('<B', raw_sd, offset+1)[0]
        ace_size = struct.unpack_from('<H', raw_sd, offset+2)[0]
        access_mask = struct.unpack_from('<I', raw_sd, offset+4)[0]
        
        ace_data = {
            'type': ace_type,
            'flags': ace_flags,
            'access_mask': access_mask,
            'object_type': None,
            'inherited_object_type': None,
            'trustee': None,
        }
        
        if ace_type == ACCESS_ALLOWED_OBJECT_ACE:
            obj_flags = struct.unpack_from('<I', raw_sd, offset+8)[0]
            ptr = offset + 12
            if obj_flags & 1:  # ACE_OBJECT_TYPE_PRESENT
                ace_data['object_type'] = parse_guid(raw_sd, ptr)
                ptr += 16
            if obj_flags & 2:  # ACE_INHERITED_OBJECT_TYPE_PRESENT
                ace_data['inherited_object_type'] = parse_guid(raw_sd, ptr)
                ptr += 16
            sid, _ = parse_sid(raw_sd, ptr)
            ace_data['trustee'] = sid
        elif ace_type == ACCESS_ALLOWED_ACE:
            sid, _ = parse_sid(raw_sd, offset+8)
            ace_data['trustee'] = sid
        
        aces.append(ace_data)
        offset += ace_size
    
    return aces

# Connect
