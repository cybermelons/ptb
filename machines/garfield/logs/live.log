[10:26:29] RUN: # Try with the correct .NET Message Framing - maybe needs Windows upgrade negotiation
python3 -c "
import socket

sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.settimeout(10)
sock.connect(('10.129.17.178', 9389))

# .NET Message Framing preamble
# Version Record: type=0x00, major=1, minor=0  
version = bytes([0x00, 0x01, 0x00])
# Mode Record: type=0x01, mode=0x02 (Duplex)
mode = bytes([0x01, 0x02])
# Via Record
via_url = b'net.tcp://10.129.17.178:9389/ActiveDirectoryWebServices/Windows'
via = bytes([0x02, len(via_url)]) + via_url
# Upgrade Record for Negotiate auth
upgrade_type = b'application/negotiate'
upgrade = bytes([0x09, len(upgrade_type)]) + upgrade_type
# Preamble End
preamble_end = bytes([0x0C])

payload = version + mode + via + preamble_end
sock.sendall(payload)

import select
ready = select.select([sock], [], [], 5)
if ready[0]:
    data = sock.recv(4096)
    print(f'Response hex: {data.hex()}')
    print(f'Response len: {len(data)}')
    if data[0:1] == b'\x0b':
        print('Preamble ACK received - ADWS accepts connections')
    elif data[0:1] == b'\x0a':
        print('Upgrade response received')
    else:
        print(f'Unknown response type: {hex(data[0])}')
else:
    print('No response within 5s')

sock.close()
" 2>&1
