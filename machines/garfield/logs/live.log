[10:26:17] RUN: python3 -c "
import socket, ssl, struct

# Try raw TCP connection to ADWS port 9389 - .NET Message Framing probe
sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.settimeout(10)
sock.connect(('10.129.17.178', 9389))

# .NET Message Framing: Version Record (0x00) + Mode Record (0x01) + Via Record (0x02)
# Version: Major=1, Minor=0
version_record = bytes([0x00, 0x01, 0x00])
# Mode: Singleton-Unsized (0x01) 
mode_record = bytes([0x01, 0x01])
# Via: net.tcp://10.129.17.178:9389/ActiveDirectoryWebServices/Windows
via_url = b'net.tcp://10.129.17.178:9389/ActiveDirectoryWebServices/Windows'
via_len = len(via_url)
via_record = bytes([0x02]) + bytes([via_len]) + via_url

# Send framing preamble
sock.sendall(version_record + mode_record + via_record)

# Preamble End record
sock.sendall(bytes([0x0C]))

# Read response
data = sock.recv(4096)
print(f'Response bytes: {data.hex()}')
print(f'Response raw: {data}')
print(f'Response length: {len(data)}')

# Byte 0 should be 0x0B (Preamble Ack) if server accepts
if data and data[0] == 0x0b:
    print('SUCCESS: Server acknowledged .NET Message Framing preamble')
else:
    print(f'Server response code: {hex(data[0]) if data else \"empty\"}')

sock.close()
" 2>&1
