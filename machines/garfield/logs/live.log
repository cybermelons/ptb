)

if not conn.entries:
    print("ERROR: Target not found")
    exit(1)

raw_sd = conn.entries[0].nTSecurityDescriptor.raw_values[0]
aces = parse_sd(raw_sd)

# Filter ACEs for j.arbuckle or IT Support SIDs
target_sids = set()
if jarb_sid:
    target_sids.add(jarb_sid)
if it_sid:
    target_sids.add(it_sid)

print(f"\nTarget SIDs: {target_sids}")
print(f"Total ACEs on l.wilson: {len(aces)}")
print(f"\n=== ACEs matching j.arbuckle / IT Support ===")

matching = []
for ace in aces:
    if ace['trustee'] in target_sids:
        matching.append(ace)
        mask = ace['access_mask']
        obj_guid = ace['object_type'] or "N/A"
        inh_guid = ace['inherited_object_type'] or "N/A"
        
        # Resolve GUID name
        guid_name = KNOWN_GUIDS.get(obj_guid, "UNKNOWN") if obj_guid != "N/A" else "N/A"
        inh_name = KNOWN_GUIDS.get(inh_guid, "UNKNOWN") if inh_guid != "N/A" else "N/A"
        
        # Decode access mask
        rights = []
        if mask & ADS_RIGHT_DS_WRITE_PROP: rights.append("WriteProp")
        if mask & ADS_RIGHT_DS_SELF: rights.append("Self")
        if mask & GENERIC_WRITE: rights.append("GenericWrite")
        if mask & WRITE_DAC: rights.append("WriteDACL")
        if mask & WRITE_OWNER: rights.append("WriteOwner")
        if mask & GENERIC_ALL: rights.append("GenericAll")
        if mask & ADS_RIGHT_DS_CONTROL_ACCESS: rights.append("ControlAccess")
        
        print(f"  ACE Type: {ace['type']}, Mask: 0x{mask:08x} ({','.join(rights) or 'other'})")
        print(f"    ObjectType: {obj_guid} ({guid_name})")
        print(f"    InheritedObjectType: {inh_guid} ({inh_name})")
        print(f"    Trustee: {ace['trustee']}")
        print()

if not matching:
    print("  NO matching ACEs found!")

# Also look up ALL object ACE GUIDs against schema for anything unknown
print("\n=== Schema GUID lookup for unknown GUIDs ===")
unknown_guids = set()
for ace in matching:
    if ace['object_type'] and ace['object_type'] not in KNOWN_GUIDS:
        unknown_guids.add(ace['object_type'])
    if ace['inherited_object_type'] and ace['inherited_object_type'] not in KNOWN_GUIDS:
        unknown_guids.add(ace['inherited_object_type'])

