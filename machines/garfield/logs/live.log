}

def parse_sid(data, offset):
    rev = data[offset]; sc = data[offset+1]
    auth = int.from_bytes(data[offset+2:offset+8], 'big')
    subs = [str(struct.unpack_from('<I', data, offset+8+4*i)[0]) for i in range(sc)]
    return f"S-{rev}-{auth}-" + "-".join(subs), offset+8+4*sc

def parse_guid(data, offset):
    return str(uuid.UUID(bytes_le=data[offset:offset+16])), offset+16

def parse_ace(data, offset):
    atype = data[offset]; aflags = data[offset+1]
    asize = struct.unpack_from('<H', data, offset+2)[0]
    pos = offset + 4
    mask = struct.unpack_from('<I', data, pos)[0]; pos += 4
    ot = it = None
    if atype in (0x05, 0x06):
        of = struct.unpack_from('<I', data, pos)[0]; pos += 4
        if of & 1: ot, pos = parse_guid(data, pos)
        if of & 2: it, pos = parse_guid(data, pos)
    sid, _ = parse_sid(data, pos)
    return {"type": atype, "mask": mask, "object_type": ot, "inherited_object_type": it, "trustee": sid}, offset+asize

