        print(f"  Mask: {mask_str(ace['mask'])} (0x{ace['mask']:08x})")
        print(f"  ObjectType: {ot_name} ({ot})")
        print(f"  InheritedObjType: {it_name}")
        print()

print(f"[*] Total matching ACEs: {found}")

