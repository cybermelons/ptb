    "bf967a0a-0de6-11d0-a285-00aa003049e2": "pwdLastSet",
    "bf967961-0de6-11d0-a285-00aa003049e2": "givenName",
    "bf9679ab-0de6-11d0-a285-00aa003049e2": "sn",
    "bf967a9c-0de6-11d0-a285-00aa003049e2": "member",
    "bf9679c3-0de6-11d0-a285-00aa003049e2": "telephoneNumber",
    "bf967966-0de6-11d0-a285-00aa003049e2": "homeDirectory",
    "bf967967-0de6-11d0-a285-00aa003049e2": "homeDrive",
