import socket
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.settimeout(10)
s.connect(('10.129.17.178', 2179))
# vmrdp uses a custom protocol - try sending the Hyper-V VM connect magic
# The protocol starts with a VM GUID negotiation
# Send minimal bytes to see what error we get
s.send(b'\x00\x00\x00\x00')
import select
ready = select.select([s], [], [], 5)
if ready[0]:
    data = s.recv(4096)
    print('Response ({} bytes): {}'.format(len(data), data.hex()))
    print('ASCII:', repr(data))
else:
    print('No response after 4 null bytes')
    # Try more data
    s.send(b'\x01' * 16)
    ready2 = select.select([s], [], [], 5)
    if ready2[0]:
        data = s.recv(4096)
        print('Response2 ({} bytes): {}'.format(len(data), data.hex()))
    else:
        print('Still no response')
s.close()
" 2>&1; echo "---EXIT:$?---"
