import pyasn1.type.univ as univ
from pyasn1.codec.ber import encoder
sd_flags_value = encoder.encode(univ.Integer(0x04))
sd_control = ("1.2.840.113556.1.4.801", True, sd_flags_value)

conn.search(TARGET_DN, "(objectClass=*)", search_scope=ldap3.BASE, 
