    "1131f6aa-9c07-11d1-f79f-00c04fc2dcd2": "DS-Replication-Get-Changes",
    "1131f6ad-9c07-11d1-f79f-00c04fc2dcd2": "DS-Replication-Get-Changes-All",
}

# Access mask flags
ADS_RIGHT_DS_READ_PROP = 0x10
ADS_RIGHT_DS_WRITE_PROP = 0x20
ADS_RIGHT_DS_CREATE_CHILD = 0x01
ADS_RIGHT_DS_DELETE_CHILD = 0x02
ADS_RIGHT_DS_SELF = 0x08
ADS_RIGHT_DS_CONTROL_ACCESS = 0x100
GENERIC_ALL = 0x10000000
GENERIC_WRITE = 0x40000000
WRITE_DAC = 0x40000
WRITE_OWNER = 0x80000

ACE_TYPE_NAMES = {
    0x00: "ACCESS_ALLOWED",
    0x05: "ACCESS_ALLOWED_OBJECT",
    0x01: "ACCESS_DENIED",
    0x06: "ACCESS_DENIED_OBJECT",
}

def parse_sid(data, offset):
    revision = data[offset]
    sub_count = data[offset+1]
    authority = int.from_bytes(data[offset+2:offset+8], 'big')
    subs = []
    for i in range(sub_count):
        sub = struct.unpack_from('<I', data, offset+8+4*i)[0]
        subs.append(str(sub))
    sid_str = f"S-{revision}-{authority}-" + "-".join(subs)
    return sid_str, offset + 8 + 4*sub_count

def parse_guid(data, offset):
    raw = data[offset:offset+16]
    if len(raw) < 16:
        return None, offset
    g = uuid.UUID(bytes_le=raw)
    return str(g), offset+16

def parse_ace(data, offset):
    ace_type = data[offset]
    ace_flags = data[offset+1]
    ace_size = struct.unpack_from('<H', data, offset+2)[0]
    ace_end = offset + ace_size
    
    result = {"type": ace_type, "type_name": ACE_TYPE_NAMES.get(ace_type, f"UNKNOWN({ace_type:02x})"), "flags": ace_flags}
    
    pos = offset + 4
    mask = struct.unpack_from('<I', data, pos)[0]
    result["mask"] = mask
    pos += 4
    
    result["object_type"] = None
    result["inherited_object_type"] = None
    
    if ace_type in (0x05, 0x06):  # Object ACE types
        obj_flags = struct.unpack_from('<I', data, pos)[0]
        pos += 4
        if obj_flags & 0x01:  # ACE_OBJECT_TYPE_PRESENT
            guid, pos = parse_guid(data, pos)
            result["object_type"] = guid
        if obj_flags & 0x02:  # ACE_INHERITED_OBJECT_TYPE_PRESENT
            guid, pos = parse_guid(data, pos)
            result["inherited_object_type"] = guid
    
    sid, _ = parse_sid(data, pos)
    result["trustee_sid"] = sid
    
    return result, ace_end

def decode_mask(mask):
    parts = []
    if mask & GENERIC_ALL: parts.append("GenericAll")
    if mask & GENERIC_WRITE: parts.append("GenericWrite")
    if mask & WRITE_DAC: parts.append("WriteDACL")
    if mask & WRITE_OWNER: parts.append("WriteOwner")
    if mask & ADS_RIGHT_DS_WRITE_PROP: parts.append("WriteProp")
    if mask & ADS_RIGHT_DS_READ_PROP: parts.append("ReadProp")
    if mask & ADS_RIGHT_DS_CREATE_CHILD: parts.append("CreateChild")
    if mask & ADS_RIGHT_DS_DELETE_CHILD: parts.append("DeleteChild")
    if mask & ADS_RIGHT_DS_SELF: parts.append("Self")
    if mask & ADS_RIGHT_DS_CONTROL_ACCESS: parts.append("ControlAccess")
    if not parts:
        parts.append(f"0x{mask:08x}")
    return "|".join(parts)

server = ldap3.Server(DC_IP, get_info=ldap3.ALL)
conn = ldap3.Connection(server, user=f"{DOMAIN}\\{USERNAME}", password=PASSWORD, authentication=ldap3.NTLM, auto_bind=True)

# Get IT Support and j.arbuckle SIDs
conn.search("DC=garfield,DC=htb", "(|(cn=IT Support)(sAMAccountName=j.arbuckle))", attributes=["objectSid", "cn", "sAMAccountName"])
target_sids = {}
for entry in conn.entries:
    sid_bytes = entry["objectSid"].raw_values[0]
    sid_str, _ = parse_sid(sid_bytes, 0)
    name = str(entry["cn"]) if "sAMAccountName" not in str(entry) else str(entry.entry_dn)
    target_sids[sid_str] = name
    print(f"[*] {name}: {sid_str}")

# Read nTSecurityDescriptor on l.wilson with DACL-only flag
conn.search(
    TARGET_DN,
    "(objectClass=*)",
    search_scope=ldap3.BASE,
    attributes=["nTSecurityDescriptor"],
    controls=[security_descriptor_control(sdflags=0x04)]  # DACL only
)

if not conn.entries:
    print("[-] Could not read nTSecurityDescriptor")
    exit(1)

sd_bytes = conn.entries[0]["nTSecurityDescriptor"].raw_values[0]

# Parse SD header
revision = sd_bytes[0]
control = struct.unpack_from('<H', sd_bytes, 2)[0]
dacl_offset = struct.unpack_from('<I', sd_bytes, 16)[0]

if dacl_offset == 0:
    print("[-] No DACL present")
    exit(1)

# Parse DACL
dacl_revision = sd_bytes[dacl_offset]
dacl_size = struct.unpack_from('<H', sd_bytes, dacl_offset+2)[0]
ace_count = struct.unpack_from('<H', sd_bytes, dacl_offset+4)[0]

print(f"\n[*] DACL: {ace_count} ACEs total on {TARGET_DN}")
print(f"[*] Looking for ACEs matching: {target_sids}")
print()

pos = dacl_offset + 8
matched = 0
for i in range(ace_count):
    ace, pos = parse_ace(sd_bytes, pos)
    if ace["trustee_sid"] in target_sids:
        matched += 1
        trustee_name = target_sids[ace["trustee_sid"]]
        obj_guid = ace["object_type"] or "ALL"
        inh_guid = ace["inherited_object_type"] or "N/A"
        
        obj_name = KNOWN_GUIDS.get(obj_guid, f"UNKNOWN({obj_guid})") if obj_guid != "ALL" else "ALL PROPERTIES"
        inh_name = KNOWN_GUIDS.get(inh_guid, f"UNKNOWN({inh_guid})") if inh_guid != "N/A" else "N/A"
        
        print(f"[ACE {i}] Trustee: {trustee_name} ({ace['trustee_sid']})")
        print(f"  Type: {ace['type_name']}")
        print(f"  Mask: {decode_mask(ace['mask'])} (0x{ace['mask']:08x})")
        print(f"  ObjectType: {obj_name} ({obj_guid})")
        print(f"  InheritedObjectType: {inh_name} ({inh_guid})")
        print()

print(f"[*] Total matching ACEs: {matched}")

# Also enumerate ACEs on the Allowed RODC PRG group
print("\n" + "="*60)
print("[*] Also checking ACEs on 'Allowed RODC Password Replication Group'")
conn.search(
    "DC=garfield,DC=htb",
    "(cn=Allowed RODC Password Replication Group)",
    attributes=["distinguishedName"]
)
if conn.entries:
    rodc_grp_dn = str(conn.entries[0].entry_dn)
    conn.search(
        rodc_grp_dn,
        "(objectClass=*)",
        search_scope=ldap3.BASE,
        attributes=["nTSecurityDescriptor"],
        controls=[security_descriptor_control(sdflags=0x04)]
    )
    if conn.entries:
        sd2 = conn.entries[0]["nTSecurityDescriptor"].raw_values[0]
        dacl_offset2 = struct.unpack_from('<I', sd2, 16)[0]
        ace_count2 = struct.unpack_from('<H', sd2, dacl_offset2+4)[0]
        pos2 = dacl_offset2 + 8
        matched2 = 0
        for i in range(ace_count2):
            ace, pos2 = parse_ace(sd2, pos2)
            if ace["trustee_sid"] in target_sids:
                matched2 += 1
                trustee_name = target_sids[ace["trustee_sid"]]
                obj_guid = ace["object_type"] or "ALL"
                obj_name = KNOWN_GUIDS.get(obj_guid, f"UNKNOWN({obj_guid})") if obj_guid != "ALL" else "ALL PROPERTIES"
                print(f"[ACE {i}] Trustee: {trustee_name} ({ace['trustee_sid']})")
                print(f"  Type: {ace['type_name']}")
                print(f"  Mask: {decode_mask(ace['mask'])} (0x{ace['mask']:08x})")
                print(f"  ObjectType: {obj_name} ({obj_guid})")
                print()
        print(f"[*] Total matching ACEs on RODC PRG: {matched2}")

# Also do a schema GUID lookup for any unknown GUIDs we found
print("\n" + "="*60)
print("[*] Checking schema for bf9679a8 GUID mapping (verification)")
conn.search(
    f"CN=Schema,CN=Configuration,DC=garfield,DC=htb",
    f"(schemaIDGUID=\\a8\\79\\96\\bf\\e6\\0d\\d0\\11\\a2\\85\\00\\aa\\00\\30\\49\\e2)",
    attributes=["cn", "lDAPDisplayName", "schemaIDGUID"]
)
for e in conn.entries:
    print(f"  {e['lDAPDisplayName']}: {e.entry_dn}")
