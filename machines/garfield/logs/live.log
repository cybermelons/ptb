[12:02:59] RUN: python3 -c "
import http.server, socketserver, sys, threading, time

class Handler(http.server.BaseHTTPRequestHandler):
    def do_POST(self):
        length = int(self.headers.get('Content-Length', 0))
        body = self.rfile.read(length).decode('utf-8', errors='replace')
        with open('/tmp/callback_result.txt', 'w') as f:
            f.write(body)
        self.send_response(200)
        self.end_headers()
        self.wfile.write(b'OK')
        print(f'CALLBACK RECEIVED: {body[:500]}', flush=True)
    def do_GET(self):
        self.send_response(200)
        self.end_headers()
        self.wfile.write(b'OK')
        print('GET callback received', flush=True)
    def log_message(self, format, *args):
        print(f'HTTP: {format % args}', flush=True)

httpd = socketserver.TCPServer(('0.0.0.0', 8080), Handler)
httpd.timeout = 120
print('Listening on :8080', flush=True)
httpd.handle_request()
httpd.handle_request()
httpd.handle_request()
print('Done listening', flush=True)
" 2>&1
