            conn.search(
                f"CN=Extended-Rights,CN=Configuration,DC=garfield,DC=htb",
                f"(rightsGuid={guid})",
                attributes=["cn", "displayName"]
            )
            if conn.entries:
                entry = conn.entries[0]
                print(f"  {guid} => Extended Right: {entry.displayName.value} ({entry.cn.value})")
            else:
                print(f"  {guid} => NOT FOUND in schema or extended rights")
else:
    print("  No unknown GUIDs to resolve")

conn.unbind()
