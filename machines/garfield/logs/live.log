import http.server, sys, signal, time

class Handler(http.server.BaseHTTPRequestHandler):
    def do_POST(self):
        length = int(self.headers.get('Content-Length', 0))
        body = self.rfile.read(length).decode('utf-8', errors='replace')
        print(f'[POST] {self.path}')
        print(f'[BODY] {body}')
        self.send_response(200)
        self.end_headers()
        self.wfile.write(b'OK')
        with open('/tmp/callback_received.txt','w') as f:
            f.write(f'{self.path}\n{body}')
    def do_GET(self):
        print(f'[GET] {self.path}')
        self.send_response(200)
        self.end_headers()
        self.wfile.write(b'OK')
        with open('/tmp/callback_received.txt','w') as f:
            f.write(f'GET {self.path}')
    def log_message(self, format, *args): pass

srv = http.server.HTTPServer(('0.0.0.0', 8080), Handler)
srv.timeout = 120
print('Listening on 0.0.0.0:8080...')
sys.stdout.flush()
start = time.time()
while time.time() - start < 120:
    srv.handle_request()
    import os
    if os.path.exists('/tmp/callback_received.txt'):
        print('Callback received, exiting')
        break
print('Listener done')
" 2>&1
