    parts = []
    if m & 0x10000000: parts.append("GenericAll")
    if m & 0x40000000: parts.append("GenericWrite")
    if m & 0x40000: parts.append("WriteDACL")
    if m & 0x80000: parts.append("WriteOwner")
    if m & 0x20: parts.append("WriteProp")
    if m & 0x10: parts.append("ReadProp")
    if m & 0x08: parts.append("Self")
    if m & 0x100: parts.append("ControlAccess")
    return "|".join(parts) if parts else f"0x{m:08x}"

