sd = conn.entries[0]["nTSecurityDescriptor"].raw_values[0]
dacl_off = struct.unpack_from('<I', sd, 16)[0]
ace_count = struct.unpack_from('<H', sd, dacl_off+4)[0]
print(f"\n[*] {ace_count} ACEs on {TARGET_DN}")
print(f"[*] Filtering for SIDs: {sids}\n")

pos = dacl_off + 8
found = 0
